<Window x:Class="CyberBotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot Companion" Height="760" Width="1100"
        WindowStartupLocation="CenterScreen" Background="#0D1117">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBg" Color="#0D1117"/>
        <SolidColorBrush x:Key="PanelBg" Color="#161B22"/>
        <SolidColorBrush x:Key="BorderColor" Color="#30363D"/>
        <SolidColorBrush x:Key="TextMain" Color="#E6EDF3"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8B949E"/>
        <SolidColorBrush x:Key="AccentCyan" Color="#00E5FF"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#3FB950"/>
        <SolidColorBrush x:Key="AccentRed" Color="#F85149"/>
        <SolidColorBrush x:Key="AccentYellow" Color="#E3B341"/>

        <!-- Rounded button style used throughout the app -->
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Padding" Value="12,7,12,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentCyan}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="14,8,14,8"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════ MENU STRIP ══════════════════════ -->
        <Menu Grid.Row="0" Background="{StaticResource PanelBg}" Foreground="{StaticResource TextMain}">
            <MenuItem Header="_File">
                <MenuItem Header="Refresh Current Tab" Click="MenuRefresh_Click"/>
                <Separator/>
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Task Manager" Click="MenuGoToTasks_Click"/>
                <MenuItem Header="Activity Log" Click="MenuGoToLog_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="About CyberBot" Click="MenuGoToAbout_Click"/>
            </MenuItem>
        </Menu>

        <!-- ══════════════════════ MAIN TAB CONTROL ══════════════════════ -->
        <TabControl x:Name="MainTabs" Grid.Row="1" Background="{StaticResource WindowBg}" BorderThickness="0" Margin="8">

            <!-- ───────────────────────── TAB: CHATBOT ───────────────────────── -->
            <TabItem Header="🤖 Chatbot">
                <Grid Background="{StaticResource WindowBg}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
                        <Grid Margin="15">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock x:Name="TitleLabel" Text="CyberG Hub" Foreground="{StaticResource AccentCyan}" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/>
                                <TextBlock Text="Local Security Sandbox" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,4,0,16"/>
                                <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Margin="0,0,0,15"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" VerticalAlignment="Top">
                                <TextBlock Text="SESSION PARAMETERS" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock x:Name="MemoryUserLabel" Text="👤 Name: Guest" Foreground="{StaticResource TextMain}" FontSize="13" Margin="0,4,0,4"/>
                                <TextBlock x:Name="MemoryTopicLabel" Text="⭐ Interest: –" Foreground="{StaticResource TextMain}" FontSize="13" Margin="0,4,0,4"/>
                                <TextBlock x:Name="MemorySentimentLabel" Text="💬 Mood: –" Foreground="{StaticResource TextMain}" FontSize="13" Margin="0,4,0,4"/>

                                <TextBlock Text="QUICK ACTIONS" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Bold" Margin="0,20,0,10"/>
                                <Button Content="📋 Show My Tasks" Click="QuickShowTasks_Click" Style="{StaticResource RoundedButton}" HorizontalAlignment="Stretch" Margin="0,0,0,6"/>
                                <Button Content="🧠 Start Quiz" Click="QuickStartQuiz_Click" Style="{StaticResource RoundedButton}" HorizontalAlignment="Stretch" Margin="0,0,0,6"/>
                                <Button Content="📜 Activity Log" Click="QuickShowLog_Click" Style="{StaticResource RoundedButton}" HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2">
                                <Button Content="Clear Chat History" Click="ClearChat_Click" Background="#21262D" Foreground="{StaticResource AccentRed}" BorderBrush="{StaticResource BorderColor}" Style="{StaticResource RoundedButton}" HorizontalAlignment="Stretch" Margin="0,0,0,8"/>
                                <Button Content="Terminate Session" Click="Exit_Click" Style="{StaticResource RoundedButton}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1" Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,10">
                            <ItemsControl x:Name="TopicButtons">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding}" Click="TopicButton_Click" Style="{StaticResource RoundedButton}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <ScrollViewer Grid.Row="1" x:Name="ChatScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,5,0,15">
                            <StackPanel x:Name="ChatPanel"/>
                        </ScrollViewer>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" x:Name="InputBox" Background="{StaticResource PanelBg}" Foreground="{StaticResource TextMain}" BorderBrush="{StaticResource BorderColor}" Padding="8" FontSize="14" KeyDown="InputBox_KeyDown" VerticalContentAlignment="Center"
                                     ToolTip="Try: 'add task to update my password', 'show my tasks', 'start quiz', 'activity log', or ask about any cyber topic."/>
                            <Button Grid.Column="1" x:Name="SendButton" Content="Send" Click="Send_Click" Background="#238636" Foreground="White" BorderBrush="{StaticResource BorderColor}" Style="{StaticResource RoundedButton}" Margin="8,0,0,0" FontWeight="Bold"/>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ───────────────────────── TAB: TASK MANAGER ───────────────────────── -->
            <TabItem Header="✅ Task Manager">
                <Grid Margin="15" Background="{StaticResource WindowBg}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Task entry form -->
                    <Border Grid.Column="0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="📝 Task Details" Style="{StaticResource SectionHeader}"/>

                            <TextBlock Text="TASK TITLE" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TaskTitleBox" Background="{StaticResource WindowBg}" Foreground="{StaticResource TextMain}" BorderBrush="{StaticResource BorderColor}" Padding="6" Margin="0,0,0,12"/>

                            <TextBlock Text="DESCRIPTION" Style="{StaticResource FieldLabel}"/>
                            <RichTextBox x:Name="TaskDescriptionBox" Height="100" Background="{StaticResource WindowBg}" Foreground="{StaticResource TextMain}" BorderBrush="{StaticResource BorderColor}" Margin="0,0,0,12"/>

                            <TextBlock Text="REMINDER DATE (optional)" Style="{StaticResource FieldLabel}"/>
                            <DatePicker x:Name="TaskReminderPicker" Margin="0,0,0,4"/>
                            <CheckBox x:Name="TaskNoReminderCheck" Content="No reminder" Foreground="{StaticResource TextMuted}" Margin="0,4,0,12" Checked="TaskNoReminderCheck_Changed" Unchecked="TaskNoReminderCheck_Changed"/>

                            <WrapPanel Margin="0,4,0,0">
                                <Button Content="➕ Add Task" Click="AddTask_Click" Background="#238636" Foreground="White" Style="{StaticResource RoundedButton}"/>
                                <Button Content="✏️ Update Task" Click="UpdateTask_Click" Style="{StaticResource RoundedButton}"/>
                                <Button Content="🗑 Delete Task" Click="DeleteTask_Click" Background="#21262D" Foreground="{StaticResource AccentRed}" Style="{StaticResource RoundedButton}"/>
                            </WrapPanel>
                            <WrapPanel Margin="0,8,0,0">
                                <Button Content="☑ Mark Complete" Click="MarkComplete_Click" Style="{StaticResource RoundedButton}"/>
                                <Button Content="🔄 View Tasks" Click="ViewTasks_Click" Style="{StaticResource RoundedButton}"/>
                                <Button Content="🧹 Clear" Click="ClearTaskForm_Click" Style="{StaticResource RoundedButton}"/>
                            </WrapPanel>

                            <TextBlock x:Name="TaskStatusText" Foreground="{StaticResource AccentYellow}" Margin="0,14,0,0" TextWrapping="Wrap" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <!-- Task list -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TaskSearchBox" Grid.Column="0" Background="{StaticResource PanelBg}" Foreground="{StaticResource TextMain}" BorderBrush="{StaticResource BorderColor}" Padding="6" ToolTip="Search tasks by title or description"/>
                            <Button Grid.Column="1" Content="🔎 Search" Click="SearchTasks_Click" Style="{StaticResource RoundedButton}" Margin="8,0,0,0"/>
                        </Grid>

                        <DataGrid x:Name="TasksGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="{StaticResource PanelBg}" Foreground="{StaticResource TextMain}" BorderBrush="{StaticResource BorderColor}"
                                  RowBackground="{StaticResource PanelBg}" AlternatingRowBackground="#1C2129" GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column" SelectionMode="Single" SelectionChanged="TasksGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding TaskID}" Width="40"/>
                                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*"/>
                                <DataGridTextColumn Header="Reminder" Binding="{Binding ReminderDate, StringFormat='dd MMM yyyy'}" Width="100"/>
                                <DataGridCheckBoxColumn Header="Done" Binding="{Binding IsCompleted}" Width="50"/>
                                <DataGridTextColumn Header="Created" Binding="{Binding DateCreated, StringFormat='dd MMM yyyy'}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ───────────────────────── TAB: QUIZ ───────────────────────── -->
            <TabItem Header="🧠 Quiz">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="QuizProgressText" Text="Press Start Quiz to begin." Foreground="{StaticResource TextMuted}" FontSize="13"/>
                            <ProgressBar x:Name="QuizProgressBar" Height="10" Minimum="0" Maximum="1" Value="0" Margin="0,6,0,0" Background="{StaticResource PanelBg}" Foreground="{StaticResource AccentCyan}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" x:Name="QuizScoreText" Text="Score: 0 / 0" Foreground="{StaticResource AccentYellow}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="20,0,0,0"/>
                    </Grid>

                    <Border Grid.Row="1" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="20">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="QuizContentPanel" VerticalAlignment="Top">
                            <TextBlock x:Name="QuizTopicText" Text="" Foreground="{StaticResource AccentCyan}" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBlock x:Name="QuizQuestionText" Text="Welcome to the CyberBot Security Quiz! Click 'Start Quiz' below to test your knowledge across 13 cybersecurity topics." Foreground="{StaticResource TextMain}" FontSize="16" TextWrapping="Wrap" Margin="0,0,0,16"/>
                            <ListBox x:Name="QuizOptionsList" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextMain}" FontSize="14" SelectionChanged="QuizOptionsList_SelectionChanged"/>
                            <TextBlock x:Name="QuizFeedbackText" FontSize="14" FontWeight="Bold" TextWrapping="Wrap" Margin="0,16,0,0"/>
                            <TextBlock x:Name="QuizExplanationText" FontSize="13" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,4,0,0"/>

                            <ItemsControl x:Name="QuizReviewList" Margin="0,10,0,0"/>
                        </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <WrapPanel Grid.Row="2" Margin="0,12,0,0">
                        <Button Content="▶ Start Quiz" Click="StartQuiz_Click" Background="#238636" Foreground="White" Style="{StaticResource RoundedButton}"/>
                        <Button Content="✔ Submit Answer" Click="SubmitAnswer_Click" Style="{StaticResource RoundedButton}"/>
                        <Button Content="⏭ Next Question" Click="NextQuestion_Click" Style="{StaticResource RoundedButton}"/>
                        <Button Content="🔁 Restart Quiz" Click="RestartQuiz_Click" Style="{StaticResource RoundedButton}"/>
                        <Button Content="⏹ Exit Quiz" Click="ExitQuiz_Click" Background="#21262D" Foreground="{StaticResource AccentRed}" Style="{StaticResource RoundedButton}"/>
                    </WrapPanel>
                </Grid>
            </TabItem>

            <!-- ───────────────────────── TAB: ACTIVITY LOG ───────────────────────── -->
            <TabItem Header="📜 Activity Log">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="LogSearchBox" Grid.Column="0" Background="{StaticResource PanelBg}" Foreground="{StaticResource TextMain}" BorderBrush="{StaticResource BorderColor}" Padding="6" ToolTip="Search by action or details"/>
                        <WrapPanel Grid.Column="1" Margin="8,0,0,0">
                            <Button Content="🔎 Search" Click="LogSearch_Click" Style="{StaticResource RoundedButton}"/>
                            <Button Content="🔄 Refresh" Click="LogRefresh_Click" Style="{StaticResource RoundedButton}"/>
                            <CheckBox x:Name="LogShowAllCheck" Content="Show All" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="4,0,8,0" Checked="LogRefresh_Click" Unchecked="LogRefresh_Click"/>
                            <Button Content="💾 Export CSV" Click="LogExport_Click" Style="{StaticResource RoundedButton}"/>
                            <Button Content="🧹 Clear Log" Click="LogClear_Click" Background="#21262D" Foreground="{StaticResource AccentRed}" Style="{StaticResource RoundedButton}"/>
                        </WrapPanel>
                    </Grid>

                    <DataGrid x:Name="LogGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              Background="{StaticResource PanelBg}" Foreground="{StaticResource TextMain}" BorderBrush="{StaticResource BorderColor}"
                              RowBackground="{StaticResource PanelBg}" AlternatingRowBackground="#1C2129" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding DateText}" Width="100"/>
                            <DataGridTextColumn Header="Time" Binding="{Binding TimeText}" Width="80"/>
                            <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="160"/>
                            <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ───────────────────────── TAB: DATABASE ───────────────────────── -->
            <TabItem Header="🗄 Database">
                <StackPanel Margin="20" MaxWidth="500" HorizontalAlignment="Left">
                    <TextBlock Text="🗄 MySQL Connection Settings" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Text="Tasks and the Activity Log are stored in MySQL. Configure your connection below, then test it and create the schema. If the database is unreachable, the app automatically falls back to in-memory storage so nothing crashes." Foreground="{StaticResource TextMuted}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <TextBlock Text="SERVER" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="DbServerBox" Text="localhost" Background="{StaticResource PanelBg}" Foreground="{StaticResource TextMain}" BorderBrush="{StaticResource BorderColor}" Padding="6" Margin="0,0,0,10"/>

                    <TextBlock Text="PORT" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="DbPortBox" Text="3306" Background="{StaticResource PanelBg}" Foreground="{StaticResource TextMain}" BorderBrush="{StaticResource BorderColor}" Padding="6" Margin="0,0,0,10"/>

                    <TextBlock Text="DATABASE NAME" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="DbNameBox" Text="cyberbot_db" Background="{StaticResource PanelBg}" Foreground="{StaticResource TextMain}" BorderBrush="{StaticResource BorderColor}" Padding="6" Margin="0,0,0,10"/>

                    <TextBlock Text="USERNAME" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="DbUserBox" Text="root" Background="{StaticResource PanelBg}" Foreground="{StaticResource TextMain}" BorderBrush="{StaticResource BorderColor}" Padding="6" Margin="0,0,0,10"/>

                    <TextBlock Text="PASSWORD" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="DbPasswordBox" Background="{StaticResource PanelBg}" Foreground="{StaticResource TextMain}" BorderBrush="{StaticResource BorderColor}" Padding="6" Margin="0,0,0,16"/>

                    <WrapPanel>
                        <Button Content="💾 Save Settings" Click="DbSave_Click" Style="{StaticResource RoundedButton}"/>
                        <Button Content="🔌 Test Connection" Click="DbTest_Click" Style="{StaticResource RoundedButton}"/>
                        <Button Content="🏗 Initialize Schema" Click="DbInitSchema_Click" Style="{StaticResource RoundedButton}"/>
                    </WrapPanel>

                    <TextBlock x:Name="DbStatusText" Margin="0,16,0,0" Foreground="{StaticResource AccentYellow}" TextWrapping="Wrap" FontSize="12"/>
                </StackPanel>
            </TabItem>

            <!-- ───────────────────────── TAB: ABOUT ───────────────────────── -->
            <TabItem Header="ℹ About">
                <StackPanel Margin="24" MaxWidth="650">
                    <TextBlock Text="🛡 CyberBot Companion" Foreground="{StaticResource AccentCyan}" FontSize="22" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Foreground="{StaticResource TextMain}" FontSize="13" TextWrapping="Wrap" LineHeight="22" Text="CyberBot is a WPF cybersecurity awareness desktop companion. It combines a conversational chatbot with keyword/NLP-style intent recognition, a Cybersecurity Task Assistant backed by MySQL, a 13-topic interactive quiz, and a full activity log — all built using plain C# logic (no external AI services)."/>
                    <TextBlock Text="Features" Foreground="{StaticResource AccentYellow}" FontWeight="Bold" FontSize="14" Margin="0,20,0,8"/>
                    <TextBlock Foreground="{StaticResource TextMuted}" FontSize="12" TextWrapping="Wrap" LineHeight="20"
                               Text="• Chatbot with sentiment detection &amp; conversation memory&#10;• Cybersecurity Task Assistant (Add / Edit / Complete / Delete, MySQL-backed)&#10;• Reminders with automatic due/overdue detection on launch&#10;• 13-topic, 14-question quiz with scoring and explanations&#10;• Synonym-based NLP command recognition&#10;• Full Activity Log with search, export, and clear&#10;• Configurable MySQL connection with in-memory fallback"/>
                    <TextBlock Text="Version 3.0 — Part 3 Submission" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,24,0,0"/>
                </StackPanel>
            </TabItem>

        </TabControl>

        <!-- ══════════════════════ STATUS BAR ══════════════════════ -->
        <StatusBar Grid.Row="2" Background="{StaticResource PanelBg}">
            <StatusBarItem>
                <TextBlock x:Name="StatusBarText" Text="Ready." Foreground="{StaticResource TextMuted}" FontSize="11"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="DbStatusIndicator" Text="DB: Unknown" Foreground="{StaticResource TextMuted}" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
