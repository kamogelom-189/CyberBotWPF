<Window x:Class="CyberBotWPF.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome" Height="300" Width="400" WindowStartupLocation="CenterScreen" Background="#0D1117">
    <Grid>
        <MediaElement x:Name="VoiceGreeting" 
                      LoadedBehavior="Manual" 
                      Visibility="Collapsed" />

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Cyber Guardian" Foreground="#00E5FF" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
            <TextBox x:Name="NameBox" Width="250" Height="30" Background="#161B22" Foreground="#E6EDF3" BorderBrush="#30363D" Padding="5" KeyDown="NameBox_KeyDown"/>
            <Button x:Name="StartButton" Content="Launch Companion" Width="250" Height="35" Margin="0,15,0,0" Background="#238636" Foreground="White" FontWeight="Bold" Click="StartButton_Click"/>
            <TextBlock x:Name="ErrorLabel" Text="Please enter a valid handle to authenticate." Foreground="#F85149" Margin="0,10,0,0" Visibility="Collapsed" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>